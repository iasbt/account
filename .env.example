# Vercel Deployment Configuration
# 部署到 Vercel 时，请在项目设置中添加以下环境变量

# Casdoor 认证服务器地址
# 生产环境示例: https://auth.iasbt.cloud (必须是 HTTPS)
# 临时测试: http://119.91.71.30:8000 (注意：Vercel 默认强制 HTTPS，可能无法连接 HTTP 后端)
VITE_CASDOOR_SERVER_URL=http://119.91.71.30:8000

# Casdoor 应用配置
VITE_CASDOOR_CLIENT_ID=2e31f2f0cac3e22dc501
VITE_CASDOOR_ORGANIZATION_NAME=built-in
VITE_CASDOOR_APP_NAME=app-built-in

# 后端 API 地址 (PostgREST)
# 如果前端在 Vercel (HTTPS)，后端必须也是 HTTPS，否则会被浏览器 Mixed Content 拦截
# 临时解决方案：后端需要配置 SSL 证书
VITE_API_BASE_URL=http://119.91.71.30:8080/api/rest
