# Vercel Deployment Configuration
# 部署到 Vercel 时，请在项目设置中添加以下环境变量

# 后端 API 地址 (PostgREST)
# 如果前端在 Vercel (HTTPS)，后端必须也是 HTTPS，否则会被浏览器 Mixed Content 拦截
# 临时解决方案：后端需要配置 SSL 证书
VITE_API_BASE_URL=/api/rest
VITE_ALLOW_EXTERNAL_API=true
VITE_AUTH_BASE_URL=/api
VITE_AUTH_PROXY_TARGET=http://119.91.71.30:3000
VITE_API_PROXY_TARGET=http://119.91.71.30:8080
AUTH_PROXY_TARGET=http://119.91.71.30:3000
PORT=3000
DB_HOST=iasbt-postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=please_change_me
DB_NAME=postgres
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=notice@example.com
SMTP_PASS=please_change_me

# Redis Configuration
REDIS_HOST=account-redis
REDIS_PORT=6379
REDIS_PASSWORD=securepassword
CORS_ALLOWLIST=https://account.iasbt.com,https://account.iasbt.com.pages.dnsoe5.com,https://account1-76iej0ca.edgeone.dev,http://119.91.71.30,https://account-*.vercel.app,http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=info
SSO_JWT_SECRET=please_change_me
SSO_TOKEN_TTL=300
SSO_REDIRECT_ALLOWLIST=img.iasbt.com,toolbox.iasbt.com
