# Vercel Deployment Configuration
# 部署到 Vercel 时，请在项目设置中添加以下环境变量

VITE_AUTH_BASE_URL=/api
VITE_AUTH_PROXY_TARGET=http://119.91.71.30:3000
AUTH_PROXY_TARGET=http://119.91.71.30:3000
PRIMARY_DOMAIN=iasbt.cloud
ACCOUNT_PUBLIC_URL=https://account.iasbt.cloud
LOGTO_BASE_URL=https://logto.iasbt.cloud
LOGTO_ADMIN_URL=https://logto-console.iasbt.cloud
PORT=3000
DB_HOST=iasbt-postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=please_change_me
DB_NAME=postgres
PGADMIN_DEFAULT_EMAIL=admin@iasbt.com
PGADMIN_DEFAULT_PASSWORD=please_change_me
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=notice@example.com
SMTP_PASS=please_change_me

# Redis Configuration
REDIS_HOST=account-redis
REDIS_PORT=6379
REDIS_PASSWORD=securepassword
CORS_ALLOWLIST=https://account.iasbt.cloud,https://www.iasbt.cloud,https://iasbt.cloud,http://119.91.71.30,https://119.91.71.30,https://account-*.vercel.app,http://localhost:5173,http://127.0.0.1:5173,http://119.91.71.30:5173
ALLOWED_DOMAINS=.iasbt.cloud,.iasbt.com,localhost,127.0.0.1
LOG_LEVEL=info
DEBUG_ALLOWLIST=182.135.56.98

# SSO Global Secret (Fallback)
SSO_JWT_SECRET=please_change_me
SSO_TOKEN_TTL=300
# OIDC Provider
OIDC_ISSUER=https://account.iasbt.cloud
OIDC_INTERNAL_CLIENT_ID=account-web
OIDC_INTERNAL_REDIRECT_URI=https://account.iasbt.cloud
OIDC_ACCESS_TOKEN_TTL=900
OIDC_AUTH_CODE_TTL=60
OIDC_REFRESH_TOKEN_TTL=1209600
OIDC_COOKIE_KEYS=please_change_me
OIDC_EXTERNAL_ISSUER=
OIDC_EXTERNAL_JWKS_URL=
OIDC_EXTERNAL_AUDIENCE=
# Logto（推荐优先使用）
LOGTO_ISSUER=
LOGTO_JWKS_URL=
LOGTO_AUDIENCE=
AUTHENTIK_ISSUER=
AUTHENTIK_JWKS_URL=
AUTHENTIK_AUDIENCE=
# Deprecated: SSO_REDIRECT_ALLOWLIST is now managed via config/apps.js
SSO_REDIRECT_ALLOWLIST=img.iasbt.com,toolbox.iasbt.com,gallery.iasbt.com,localhost:5173

# Application Specific Secrets (Overrides Global Secret)
SSO_SECRET_GALLERY=specific_secret_for_gallery
SSO_SECRET_TOOLBOX=specific_secret_for_toolbox
SSO_SECRET_LIFEOS=specific_secret_for_lifeos
