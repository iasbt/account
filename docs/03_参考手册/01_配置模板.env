# ==============================================
# 子系统接入 Account System 配置文件模板 (Standard Template)
# 适用范围: Gallery, Toolbox, LifeOS 等接入方
# 版本: V2.0
# ==============================================

# ----------------------------------------------
# 1. 基础连接配置 (Connection)
# ----------------------------------------------

# Account 系统的主入口地址 (用户浏览器访问地址)
# 生产环境: https://account.iasbt.com
# 开发环境: http://localhost:5173 (或 http://account.local)
ACCOUNT_SSO_URL=https://account.iasbt.com

# Account 系统的 API 接口地址 (后端服务调用地址)
# 生产环境: https://account.iasbt.com/api
# Docker内部: http://account-backend:3000/api
ACCOUNT_API_URL=https://account.iasbt.com/api

# ----------------------------------------------
# 2. 应用身份标识 (Identity)
# ----------------------------------------------

# 应用唯一标识符 (App ID)
# 必须与 Account 数据库 `public.applications` 表中的 `app_id` 一致
# 示例: gallery, toolbox
APP_ID=your_app_id_here

# 应用密钥 (App Secret)
# 用于后端验证 JWT 签名，严禁泄露给前端
# 必须与 Account 数据库中的 `secret` 字段一致
APP_SECRET=your_secure_random_secret_key_here

# ----------------------------------------------
# 3. 认证回调配置 (Callback)
# ----------------------------------------------

# SSO 登录成功后的回调地址
# Account 系统将重定向至此地址，并附带 Token Hash
# 必须在 Account 数据库的 `allowed_origins` 列表中注册
# 示例: https://gallery.iasbt.com/auth/callback
SSO_CALLBACK_URL=https://your-app.iasbt.com/auth/callback

# ----------------------------------------------
# 4. 运行时配置 (Runtime)
# ----------------------------------------------

# Token 存储键名 (前端 LocalStorage Key)
# 建议统一使用: access_token
AUTH_TOKEN_KEY=access_token

# 是否启用调试模式
# true: 打印详细的 Token 验证日志
DEBUG_AUTH=false
