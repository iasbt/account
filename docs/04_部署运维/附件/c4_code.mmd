C4Component
title Account System - C4 Level 4 (代码级别)

Container(api, "API App", "Node.js + Express", "后端代码级组件")

Component(file_server, "server.js", "启动入口")
Component(file_app, "app.js", "Express 组装")
Component(file_routes, "routes/index.js", "路由聚合")
Component(file_auth_routes, "routes/authRoutes.js", "认证路由")
Component(file_auth_controller, "controllers/authController.js", "认证控制器")
Component(file_auth_service, "services/authService.js", "认证服务")
Component(file_auth_schema, "validators/authSchema.js", "输入验证")
Component(file_auth_mw, "middlewares/auth.js", "Token 校验")
Component(file_validate_mw, "middlewares/validate.js", "Schema 校验")
Component(file_rate_mw, "middlewares/rateLimit.js", "限流")
Component(file_logger_mw, "middlewares/logger.js", "请求日志")
Component(file_token_util, "utils/token.js", "JWT/SSO Token")
Component(file_email_util, "utils/email.js", "邮件发送")
Component(file_queue_util, "utils/emailQueue.js", "邮件队列")
Component(file_email_worker, "services/emailWorker.js", "邮件队列消费者")
Component(file_config, "config/index.js", "环境配置")
Component(file_db, "db.js", "数据库连接")

Rel(file_server, file_app, "启动")
Rel(file_app, file_routes, "挂载")
Rel(file_routes, file_auth_routes, "引用")
Rel(file_auth_routes, file_validate_mw, "校验")
Rel(file_auth_routes, file_auth_mw, "鉴权")
Rel(file_auth_routes, file_rate_mw, "限流")
Rel(file_auth_routes, file_auth_controller, "调用")
Rel(file_auth_controller, file_auth_service, "调用")
Rel(file_auth_service, file_db, "读写")
Rel(file_auth_service, file_token_util, "Token")
Rel(file_auth_service, file_email_util, "发送邮件")
Rel(file_email_util, file_queue_util, "推送队列")
Rel(file_queue_util, file_email_worker, "消费")
Rel(file_app, file_logger_mw, "日志")
Rel(file_app, file_config, "读取配置")
