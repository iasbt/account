C4Component
title Account System - C4 Level 3 (组件架构)

Container(api, "API App", "Node.js + Express", "后端组件")
Container(web, "Web App", "React + Vite", "前端组件")
ContainerDb(pg, "PostgreSQL", "数据存储")
Container(redis, "Redis", "队列/缓存")

Component(authRoutes, "Auth Routes", "routes/authRoutes.js", "认证入口")
Component(adminRoutes, "Admin Routes", "routes/adminRoutes.js", "管理员入口")
Component(appRoutes, "App Routes", "routes/appRoutes.js", "应用管理入口")
Component(ssoRoutes, "SSO Routes", "routes/ssoRoutes.js", "SSO 入口")
Component(dashboardRoutes, "Dashboard Routes", "routes/dashboardRoutes.js", "仪表盘入口")
Component(healthRoutes, "Health Routes", "routes/healthRoutes.js", "健康检查入口")
Component(authController, "Auth Controller", "controllers/authController.js", "认证业务协调")
Component(adminController, "Admin Controller", "controllers/adminController.js", "管理员业务协调")
Component(appController, "App Controller", "controllers/appController.js", "应用管理业务协调")
Component(ssoController, "SSO Controller", "controllers/ssoController.js", "SSO Token 发放")
Component(emailController, "Email Controller", "controllers/emailConfigController.js", "邮件配置/日志")
Component(authService, "Auth Service", "services/authService.js", "核心认证逻辑")
Component(emailWorker, "Email Worker", "services/emailWorker.js", "异步邮件发送")
Component(middlewares, "Middlewares", "middlewares/*.js", "认证/授权/校验/限流/日志")
Component(utils, "Utils", "utils/*.js", "Token/邮件/验证码")
Component(config, "Config", "config/index.js", "环境与系统配置")

Rel(authRoutes, authController, "调用")
Rel(adminRoutes, adminController, "调用")
Rel(appRoutes, appController, "调用")
Rel(ssoRoutes, ssoController, "调用")
Rel(dashboardRoutes, adminController, "调用")
Rel(healthRoutes, authController, "复用")
Rel(authController, authService, "调用")
Rel(authController, utils, "Token/邮件")
Rel(adminController, utils, "日志/邮件")
Rel(emailController, utils, "邮件")
Rel(authService, pg, "读写")
Rel(emailWorker, redis, "消费队列")
Rel(emailWorker, pg, "日志记录")
Rel(middlewares, config, "读取配置")

Component(pages, "Pages", "src/pages/*", "页面视图")
Component(services, "Services", "src/services/*", "API 调用封装")
Component(stores, "Stores", "src/store/*", "Zustand 状态")
Component(apiClient, "ApiClient", "src/services/apiClient.ts", "Token 拦截")

Rel(pages, stores, "读取/更新")
Rel(pages, services, "调用")
Rel(services, apiClient, "使用")
Rel(apiClient, api, "HTTP/JSON")
